{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SOREVID VideoGET",
  "version": "0.1.0",
  "identifier": "com.bilibili-downloader.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:5187",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SOREVID VideoGET",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "resources/bin/**/*"
    ]
  }
}
