{
  "manifest_version": 3,
  "name": "SOREVID VideoGET Integration",
  "version": "0.1.0",
  "description": "Send supported video pages from Chrome to SOREVID VideoGET.",
  "key": "",
  "minimum_chrome_version": "111",
  "permissions": ["nativeMessaging", "activeTab", "contextMenus", "scripting", "cookies", "downloads", "alarms"],
  "host_permissions": [
    "https://*.bilibili.com/*",
    "https://b23.tv/*",
    "https://*.douyin.com/*",
    "https://*.iesdouyin.com/*",
    "https://*.amemv.com/*",
    "https://*.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open in VideoGET",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.bilibili.com/*",
        "https://b23.tv/*",
        "https://*.douyin.com/*",
        "https://*.iesdouyin.com/*",
        "https://*.amemv.com/*",
        "https://*.tiktok.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.tiktok.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
